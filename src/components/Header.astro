<BannerSection />

<header class="sticky bg-white border-b border-gray-300 shadow-md">
    <div class="wrapper flex items-center justify-between gap-8 py-2">
        <h1 class="text-xl font-bold">Logo</h1>
    
        <nav class="nav" id="menu">
            <Dropdown name="Platform">
                <DropdownItem
                    title="Lorem"
                    description="Lorem ipsum dolor sit amet"    
                >
                    <Star />
                </DropdownItem>
                <DropdownItem
                    title="Lorem"
                    description="Lorem ipsum dolor sit amet"    
                >
